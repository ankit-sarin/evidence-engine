%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#0A5E56', 'primaryTextColor': '#fff', 'primaryBorderColor': '#074540', 'lineColor': '#2C2C2C', 'secondaryColor': '#EEF5F4', 'tertiaryColor': '#FFF2CC' } } }%%

flowchart TB
    subgraph SEARCH["1. SEARCH"]
        PM[PubMed<br/><i>pubmed.py</i>]
        OA[OpenAlex<br/><i>openalex.py</i>]
        DD[Deduplication<br/><i>dedup.py</i>]
        PM --> DD
        OA --> DD
    end

    subgraph SCREEN["2. SCREEN"]
        P1[Primary Screen<br/><b>qwen3:8b</b><br/><i>screener.py</i><br/>High-recall, simplified exclusions]
        P2[Verifier Screen<br/><b>gemma3:27b</b><br/><i>screener.py</i><br/>Strict, full exclusions + 4 FP tests]
        P1 --> P2
    end

    subgraph ADJGATE["3. SCREENING ADJUDICATION GATE"]
        direction TB
        S1["1 SCREENING_COMPLETE"]
        S2["2 DIAGNOSTIC_SAMPLE_COMPLETE"]
        S3["3 CATEGORIES_CONFIGURED"]
        S4["4 QUEUE_EXPORTED"]
        S5["5 ADJUDICATION_COMPLETE"]
        S1 --> S2 --> S3 --> S4 --> S5
        EXP[Export Queue<br/><i>screening_adjudicator.py</i>]
        IMP[Import Decisions<br/><i>screening_adjudicator.py</i>]
        S4 -.-> EXP
        IMP -.-> S5
    end

    subgraph PARSE["4. PARSE"]
        DIG[Digital PDF<br/><b>Docling</b><br/><i>pdf_parser.py</i>]
        SCN[Scanned PDF<br/><b>Qwen2.5-VL:7b</b><br/><i>pdf_parser.py</i>]
    end

    subgraph EXTRACT["5. EXTRACT"]
        EX1[Pass 1: Reasoning<br/><b>deepseek-r1:32b</b><br/><i>extractor.py</i>]
        EX2[Pass 2: Structured JSON<br/><b>deepseek-r1:32b</b><br/><i>extractor.py</i>]
        EX1 --> EX2
    end

    subgraph CLOUD["5b. CLOUD EXTRACT (concordance)"]
        OAI[OpenAI o4-mini<br/><i>openai_extractor.py</i><br/>reasoning_effort=high]
        ANT[Anthropic Sonnet 4.6<br/><i>anthropic_extractor.py</i><br/>extended thinking]
    end

    subgraph AUDIT["6. AUDIT"]
        GR[Grep Verify<br/><i>auditor.py</i><br/>Exact + fuzzy substring match]
        SEM[Semantic Verify<br/><b>gemma3:27b</b><br/><i>auditor.py</i><br/>LLM value-vs-source check]
        GR --> SEM
    end

    subgraph AUDITGATE["7. AUDIT REVIEW GATE"]
        direction TB
        E6["6 EXTRACTION_COMPLETE"]
        E7["7 AI_AUDIT_COMPLETE_STAGE"]
        E8["8 AUDIT_QUEUE_EXPORTED"]
        E9["9 AUDIT_REVIEW_COMPLETE"]
        E6 --> E7 --> E8 --> E9
        AEXP[Export Audit Queue<br/><i>audit_adjudicator.py</i>]
        AIMP[Import Decisions<br/><i>audit_adjudicator.py</i>]
        E8 -.-> AEXP
        AIMP -.-> E9
    end

    subgraph EXPORT["8. EXPORT"]
        PRISMA[PRISMA CSV<br/><i>prisma.py</i>]
        CSV[Evidence CSV/Excel<br/><i>evidence_table.py</i>]
        DOCX[Evidence DOCX<br/><i>docx_export.py</i>]
        METH[Methods Section<br/><i>methods_section.py</i>]
        TRACE[Traces + Quality<br/><i>trace_exporter.py</i>]
    end

    DB[(review.db<br/>SQLite)]

    %% Main flow
    DD --> DB
    DB --> P1
    P2 --> DB
    ADJGATE --> PARSE
    DB --> DIG & SCN
    DIG & SCN --> DB
    DB --> EX1
    EX2 --> DB
    DB --> OAI & ANT
    OAI & ANT --> DB
    DB --> GR
    SEM --> DB
    AUDITGATE --> EXPORT
    DB --> PRISMA & CSV & DOCX & METH & TRACE

    %% Export paths
    CSV -- "min_status=<br/>AI_AUDIT_COMPLETE" --> AI_OUT[/"AI Output<br/>(concordance)"/]
    CSV -- "min_status=<br/>HUMAN_AUDIT_COMPLETE" --> HU_OUT[/"Production Output<br/>(human-verified)"/]

    %% Stage flow
    SEARCH --> SCREEN --> ADJGATE
    PARSE --> EXTRACT
    EXTRACT --> AUDIT --> AUDITGATE

    %% Styling
    style DB fill:#B85D3A,stroke:#8B3A1F,color:#fff
    style ADJGATE fill:#FFF2CC,stroke:#D4A843
    style AUDITGATE fill:#FFF2CC,stroke:#D4A843
    style AI_OUT fill:#EEF5F4,stroke:#0A5E56
    style HU_OUT fill:#0A5E56,stroke:#074540,color:#fff
